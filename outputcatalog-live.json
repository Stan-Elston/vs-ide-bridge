      {
        "name": "Tools.IdeGetQuickInfo",
        "description": "Resolve a symbol at a file/line/column and return its definition location plus a surrounding code slice.",
        "example": "Tools.IdeGetQuickInfo --file \u0022C:\\repo\\src\\foo.cpp\u0022 --line 42 --column 13"
      },
